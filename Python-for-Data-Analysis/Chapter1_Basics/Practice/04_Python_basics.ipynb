   "outputs": [],
   "source": [
    "def isiterable(obj):\n",
    "    try:\n",
    "        iter(obj)\n",
    "        return True\n",
    "    except TypeError: #not iterable\n",
    "        return False"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b6f433a3-783b-4e39-8e0c-e88d3ab00d2f",
   "metadata": {},
   "outputs": [],
   "source": [
    "isiterable(\"a string\")"
   ]
  },
  {
   "cell_type": "code",
